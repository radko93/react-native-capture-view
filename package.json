{
  "name": "react-native-capture-view",
  "version": "0.1.0",
  "description": "Fabric-compatible React Native view, screen, and ScrollView capture for iOS and Android",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-capture-view-example",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest --passWithNoTests",
    "release": "release-it"
  },
  "keywords": [
    "react-native",
    "react-native-library",
    "screenshot",
    "snapshot",
    "capture",
    "view-capture",
    "view-shot",
    "scrollview",
    "scroll-view",
    "fabric",
    "new-architecture",
    "turbomodule",
    "expo",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/radko93/react-native-capture-view.git"
  },
  "author": "Radek Czemerys <radko93@gmail.com> (https://github.com/radko93)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/radko93/react-native-capture-view/issues"
  },
  "homepage": "https://github.com/radko93/react-native-capture-view#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@react-native/babel-preset": "0.85.1",
    "@react-native/eslint-config": "0.85.1",
    "@react-native/jest-preset": "0.85.1",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.0",
    "del-cli": "^7.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.0.0",
    "prettier": "^3.8.1",
    "react": "19.2.3",
    "react-native": "0.85.1",
    "react-native-builder-bob": "^0.41.0",
    "react-test-renderer": "19.2.5",
    "release-it": "^20.0.0",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.82.0"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RNCaptureViewSpec",
    "type": "all",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.captureview"
    },
    "ios": {
      "componentProvider": {
        "CaptureViewView": "CaptureViewView"
      }
    }
  },
  "jest": {
    "preset": "@react-native/jest-preset",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/example/__tests__"
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "create-react-native-library": {
    "type": "fabric-view",
    "languages": "kotlin-objc",
    "tools": [
      "eslint"
    ],
    "version": "0.62.0"
  }
}
